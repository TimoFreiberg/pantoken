# Shared Cargo target dir across jj worktrees — switching worktrees goes from
# "recompile everything" to instant. Uses $HOME so it's not hardcoded to a
# specific user. Requires direnv (brew install direnv; direnv allow).
# CI overrides this with CARGO_TARGET_DIR: ${{ github.workspace }}/target.
export CARGO_TARGET_DIR="$HOME/Library/Caches/pantoken-cargo-target"
